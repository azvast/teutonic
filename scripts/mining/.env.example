# =============================================================================
# Teutonic mining .env — TEMPLATE
# =============================================================================
# Copy this file to `.env` (in the same directory) and fill in real values.
#
#   cp scripts/mining/.env.example scripts/mining/.env
#   chmod 600 scripts/mining/.env
#
# `train_challenger.py` auto-loads `scripts/mining/.env` on startup. The
# bash helpers (`start.sh`, `smoke.sh`, `eval.sh`, `submit.sh`, etc.)
# also `source` it before invoking python.
#
# RULES:
#   - Existing shell env vars ALWAYS win over .env values (shell > .env).
#   - CLI flags ALWAYS win over both (CLI > shell > .env).
#   - Lines starting with `#` are comments. KEY=VALUE only — no shell expansions.
#   - Quote values containing spaces or `#`.
#
# DO NOT commit `.env` (it's in .gitignore). This template (`.env.example`)
# IS committed.
#
# Two-machine layout (recommended):
#   - GPU box: needs HF_TOKEN, HF_ACCOUNT, COLDKEY_PREFIX, WANDB_*, paths.
#               Does NOT need a wallet at all (training-only).
#   - PC (where wallet lives): needs BT_WALLET_NAME, BT_WALLET_HOTKEY,
#               TEUTONIC_NETUID, TEUTONIC_NETWORK. Does NOT need HF_TOKEN
#               (no upload from PC).
# Both boxes can share an identical .env if you don't mind copying it;
# unused vars on each side are simply ignored.

# -----------------------------------------------------------------------------
# [GPU + PC] HuggingFace — REQUIRED on the GPU box for downloading the king
# and pushing your challenger. Not used on the PC if PC only submits.
# -----------------------------------------------------------------------------
# Generate a WRITE-scope token at https://huggingface.co/settings/tokens.
HF_TOKEN=hf_REPLACE_ME

# Your HF account / org under which challengers will be pushed. Used by
# start.sh to assemble the default --upload-repo. Pick the account you
# have write quota on (~165 GiB per push for Teutonic-LXXX).
HF_ACCOUNT=your-hf-account

# Faster HF transfer client. Leave at 1.
HF_HUB_ENABLE_HF_TRANSFER=1

# -----------------------------------------------------------------------------
# [GPU + PC] Anti-impersonation gate — first 8 ss58 chars of your COLDKEY.
# REQUIRED on the GPU box (start.sh embeds it in the upload-repo name).
# REQUIRED on the PC too (submit_challenger.py re-checks before broadcasting).
# Find with `btcli wallet list` on whichever box has your wallet.
# -----------------------------------------------------------------------------
COLDKEY_PREFIX=5XXXXXXX

# -----------------------------------------------------------------------------
# [PC only] Bittensor wallet — POINTERS only. These are LABELS, not ss58
# addresses. They identify which directory under ~/.bittensor/wallets/
# to load. The actual ss58 addresses are computed from the keys inside.
#
# Created by:
#   btcli wallet new_coldkey --wallet.name <BT_WALLET_NAME>
#   btcli wallet new_hotkey  --wallet.name <BT_WALLET_NAME> \
#                            --wallet.hotkey <BT_WALLET_HOTKEY>
#
# So if you ran `--wallet.name teutonic --wallet.hotkey h0`, the files
# live at ~/.bittensor/wallets/teutonic/{coldkey,coldkeypub.txt,hotkeys/h0}
# and you set:
#   BT_WALLET_NAME=teutonic
#   BT_WALLET_HOTKEY=h0
#
# On the GPU box (training-only) these are unused except as a W&B label;
# leave the placeholders if you don't have a wallet there.
# -----------------------------------------------------------------------------
BT_WALLET_NAME=teutonic
BT_WALLET_HOTKEY=h0

# Subnet + network. Defaults are correct for SN3 mainnet.
TEUTONIC_NETUID=3
TEUTONIC_NETWORK=finney

# -----------------------------------------------------------------------------
# [GPU] Weights & Biases — optional but strongly recommended.
# Either:
#   (a) `wandb login` once on the GPU box (writes ~/.netrc), then leave
#       WANDB_API_KEY blank here, OR
#   (b) set WANDB_API_KEY explicitly below.
# -----------------------------------------------------------------------------
WANDB_API_KEY=
WANDB_PROJECT=teutonic-mining
# Optional — leave blank for your personal default workspace.
WANDB_ENTITY=

# -----------------------------------------------------------------------------
# [GPU] Hardware / paths — sane defaults for a 4xB200 box.
# -----------------------------------------------------------------------------
# Number of GPUs torchrun will use. start.sh / smoke.sh pass this to
# --n-gpus. Should match `nvidia-smi -L | wc -l` (or fewer).
N_GPUS=4

# Working dir. Holds king/, cache/, iter_*/{train,val,lora_out,merged,
# verdict}.json. Needs ~600 GiB free.
WORK_DIR=/root/teutonic-mining/work

# Path to scripts/training_bundle/. If you cloned the teutonic repo, the
# default `../training_bundle` works.
BUNDLE_DIR=../training_bundle

# tmux session name used by start.sh / tail.sh.
TMUX_SESSION=teutonic-miner

# -----------------------------------------------------------------------------
# Validator floor — DO NOT SET unless you know why.
# -----------------------------------------------------------------------------
# Overrides the validator's effect-floor delta in the offline paired eval.
# The current chain runs at fixed delta=0.0025 nats/token. Leaving this
# unset is correct.
# EVAL_DELTA=0.0025
